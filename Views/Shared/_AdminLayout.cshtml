@{
    // Use the main layout
    Layout = "_Layout";

    // Get current action name
    var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
}

<nav class="nav-bar" style="display:flex; justify-content:space-between; background-color:#e9ecef; padding:10px;">
    
    <ul class="left-nav" style="list-style:none; display:flex; gap:15px; margin:0; padding:0;">
        <li>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
               class="@(actionName == "Index" ? "active-link" : "")">Dashboard</a>
        </li>

        <li>
            <a asp-area="Admin" asp-controller="Users" asp-action="Manage"
               class="@(actionName == "Manage" ? "active-link" : "")">Manage</a>
        </li>

        <li>
            <a asp-area="Admin" asp-controller="Users" asp-action="Rights"
               class="@(actionName == "Rights" ? "active-link" : "")">Rights & Obligations</a>
        </li>
    </ul>

    <ul class="right-nav" style="list-style:none; margin:0; padding:0;">
        <li>
            <a asp-area="" asp-controller="Home" asp-action="Index">View Site</a>
        </li>
    </ul>

</nav>

<div class="admin-content" style="padding:20px;">
    @RenderBody()
</div>
