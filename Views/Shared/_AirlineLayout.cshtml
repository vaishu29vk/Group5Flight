@{
    Layout = "_Layout";

    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<nav class="nav-bar">
    <ul class="left-nav">

        <li>
            <a asp-area="Airlines" asp-controller="Flights" asp-action="Index"
               class="@(currentAction == "Index" ? "active-link" : "")">
               Dashboard
            </a>
        </li>

        <li>
            <a asp-area="Airlines" asp-controller="Flights" asp-action="Manage"
               class="@(currentAction == "Manage" ? "active-link" : "")">
               Manage
            </a>
        </li>

        <li>
            <a asp-area="Airlines" asp-controller="Flights" asp-action="Regulation"
               class="@(currentAction == "Regulation" ? "active-link" : "")">
               Regulation
            </a>
        </li>

    </ul>

    <ul class="right-nav">
        <li>
            <a asp-area="" asp-controller="Home" asp-action="Index">View Site</a>
        </li>
    </ul>
</nav>

<div class="airline-content">
    @RenderBody()
</div>
